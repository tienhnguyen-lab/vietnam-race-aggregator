# ── Copy to .env for local dev, and set these in Vercel → Project → Settings → Environment Variables ──

# Remote database (Neon Postgres). Required on Vercel — the serverless filesystem
# is read-only, so a local SQLite file can't persist. Use Neon's POOLED connection
# string (host contains "-pooler") for serverless. The Vercel–Neon integration
# sets this automatically; for manual setup, copy it from the Neon dashboard.
POSTGRES_URL=postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/dbname?sslmode=require
# DATABASE_URL is also accepted (same value) if you prefer that name.

# Secret that Vercel Cron sends as `Authorization: Bearer $CRON_SECRET`.
# Generate one with:  openssl rand -hex 32
CRON_SECRET=

# Optional: allows manually triggering a sync via the `X-Sync-Key` header
# (POST /api/sync or GET /api/cron/sync).
SYNC_KEY=

# Optional (Postgres only): the schema this app's tables live in. Defaults to
# 'race_aggregator', which isolates them from anything else in the same database
# (safe to share a Neon DB with another project). Change only if you want a
# different schema name.
# PG_SCHEMA=race_aggregator

# Local dev only: leave POSTGRES_URL/DATABASE_URL unset to fall back to a local
# SQLite races.db file. Optionally override its path:
# DB_PATH=./races.db
